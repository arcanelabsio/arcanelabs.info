{
  "name": "arcanelabs.info",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Arcane Labs company site — Vite + React SPA with markdown-driven content.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "npm run build:ssr && node scripts/prerender.mjs && node scripts/sitemap.mjs",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "mermaid": "^11.14.0",
    "plantuml-encoder": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/plantuml-encoder": "^1.4.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
